<a href="@Url.Action("Index", "Home")" class="btn-volver">← Volver al inicio</a>

@foreach (var grupo in ViewBag.Album)
{
    <h2>@grupo.Key.nombre</h2>
    <div class="album-container">
        @foreach (Figurita f in grupo.Value)
        {
            bool tengo = ViewBag.Cantidades.ContainsKey(f.idFigurita);
            string claseCard = "figurita-card";
            if (!tengo)
            {
                claseCard = "figurita-card figurita-faltante";
            }
            <div class="@claseCard">
                @if (tengo)
                {
                    <img src="/@f.img" width="150">
                    <h3>@f.nombre</h3>
                    <p>@f.numeroCamiseta</p>
                    <p class="figurita-cantidad">Tenés: @ViewBag.Cantidades[f.idFigurita]</p>
                }
                else
                {
                    <div class="figurita-silueta">?</div>
                    <h3>???</h3>
                    <p>@f.numeroCamiseta</p>
                    <p class="figurita-falta">Falta</p>
                }
            </div>
        }
    </div>
}
